VITE_API_BASE_URL=http://localhost:8080

# Kakao Developers > App > Platform key > REST API key
VITE_KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Must be registered in Kakao Developers > Kakao Login > Redirect URI.
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/login/kakao/callback

# Optional: defaults to "account_email profile_nickname".
VITE_KAKAO_SCOPE=account_email profile_nickname
