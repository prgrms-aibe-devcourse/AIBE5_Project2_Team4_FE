{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx svelte-check --threshold warning 2>&1 | head -20",
            "statusMessage": "Running svelte-check..."
          }
        ]
      }
    ]
  }
}
